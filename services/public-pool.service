[Unit]
Description=Public Pool (Bitcoin Solo Mining Pool)
After=network.target bitcoind.service
Requires=bitcoind.service

[Service]
Type=simple
User=pool
WorkingDirectory=/opt/public-pool/backend
ExecStart=/usr/bin/node dist/main.js
Restart=on-failure
RestartSec=10
NoNewPrivileges=true
ProtectSystem=full
PrivateTmp=true

[Install]
WantedBy=multi-user.target
